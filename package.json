{
  "name": "easykassa",
  "productName": "EasyKassa",
  "version": "1.0.1",
  "description": "EasyKassa — система автоматизации торговли для Казахстана",
  "main": "dist-electron/main.js",
  "author": "EasyKassa",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron-dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "bwip-js": "^4.9.0",
    "dayjs": "^1.11.10",
    "electron-log": "^5.1.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "i18next": "^25.8.18",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.344.0",
    "net": "*",
    "node-machine-id": "^1.1.12",
    "node-thermal-printer": "^4.4.1",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^6.22.1",
    "react-to-print": "^3.3.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^2.12.2",
    "serialport": "^12.0.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.19",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.12.0",
    "javascript-obfuscator": "^5.4.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.easykassa.pos",
    "productName": "EasyKassa",
    "artifactName": "EasyKassa-Setup-${version}.${ext}",
    "copyright": "Copyright © 2026 EasyKassa",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets/logo.ico",
        "to": "logo.ico"
      },
      {
        "from": "src/assets/easykassa.png",
        "to": "easykassa.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo.ico"
    },
    "nsis": {
      "shortcutName": "EasyKassa",
      "uninstallDisplayName": "EasyKassa",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "src/assets/logo.ico",
      "uninstallerIcon": "src/assets/logo.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GoodCompany555",
        "repo": "pxvcoretalisxandriqvexorumtalinexarionzqvostrami"
      }
    ]
  }
}